{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for ccmux-ide (M0 雛形段階)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:allow-version",
    "core:window:default",
    "core:event:default",
    "core:webview:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:allow-write-image",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "fs:allow-exists",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.claude/**" },
        { "path": "$HOME/.ccmux-ide-gui/**" },
        { "path": "$APPDATA/ccmux-ide/**" },
        { "path": "$APPCONFIG/ccmux-ide/**" },
        { "path": "$APPDATA/ccmux-images/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$HOME/**" }
      ]
    },
    "shell:default",
    "shell:allow-open",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "node",
          "cmd": "node",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "notification:default",
    "notification:allow-notify"
  ]
}
